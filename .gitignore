# ============================================================================
# .gitignore — HE Manager
# ----------------------------------------------------------------------------
# Repo only tracks source code, config, docs, and committed UI/assets.
# Everything else (build artifacts, derived caches, user-generated media,
# scratch/backup files, IDE state) is excluded. Run
#     git rm -r --cached <path>
# to drop something already tracked without deleting it on disk.
# ============================================================================

# --- Frontend ----------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/.vite/

# --- Backend Python toolchain -----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
backend/__pycache__/
backend/app/__pycache__/
backend/venv/
backend/.env
backend/instance/
backend/.pytest_cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Database & SQLite scratch ----------------------------------------------
*.db
*.sqlite
*.db-wal
*.db-shm
*.db.broken
*.db.corrupt-*
backend/storage/
backend/backups/
frontend/public/covers/

# --- Backend user-generated data --------------------------------------------
# Thumbnails / dedup caches / uploads — derived from the DB and regenerable
# by the scanner. Keeping ~100 MB of binary blobs in git bloats every clone
# and makes git status noisy.
backend/.thumbnails/
backend/.dedup/
backend/data/
backend/uploads/
backend/x_archive_uploads/
backend/.lostfound/
backend/_scratch/
backend/app/library.dump.sql
backend/app/library.recovered.sql
backend/app/library.recover.err

# --- External-favorite covers (user-downloaded ASMR / WNACG cover JPGs) -----
# Same rationale as .thumbnails — these are downloaded by the sync pipeline
# and grow forever with the library. Source of truth lives in the DB
# (ExternalFavoriteItem.cover_url) + the cover_path on Media rows.
covers/

# --- Claude Code working dir ------------------------------------------------
.claude/

# --- Logs --------------------------------------------------------------------
logs/
*.log
*.hprof



# --- IDE / editor state -----------------------------------------------------
.vscode/
.idea/
*.iml
*.swp
*.swo

# --- OS scratch -------------------------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.bak
